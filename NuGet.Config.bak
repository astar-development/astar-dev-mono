<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet.Config — repo root
  ════════════════════════
  This file is automatically picked up by the .NET CLI and all IDEs when
  working anywhere inside this repository.

  Sources are evaluated top-to-bottom. Place faster / more specific feeds
  first so restore times stay low.

  Credentials for GitHub Packages are NOT stored here — they are supplied
  at restore time via:
    • CI:        The 'dotnet nuget add source' step in each workflow, using
                 GITHUB_TOKEN (no secrets stored in the repo).
    • Local dev: `dotnet nuget add source` once in your user-level NuGet.Config
                 (~/.nuget/NuGet/NuGet.Config) using a Personal Access Token
                 with read:packages scope. Rider and VS Code both pick this up.
-->
<configuration>

  <packageSources>
    <!--
      Clear any machine-level or user-level sources first.
      This ensures CI runners start from a known state and aren't
      accidentally pulling from a developer's local feed.
    -->
    <clear></clear>

    <!-- Official NuGet.org feed — primary source for all public packages -->
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json"
         protocolVersion="3" />

    <!--
      GitHub Packages — your published NuGet packages live here.
      The %GITHUB_PACKAGES_TOKEN% placeholder is intentional: NuGet.Config
      supports environment variable substitution, but we prefer NOT to store
      credentials here at all. This source entry establishes the feed URL;
      credentials are added at restore time (see comment above).

      Replace 'your-org' with your actual GitHub username or organisation.
    -->
    <add key="github"
         value="https://nuget.pkg.github.com/your-org/index.json"
         protocolVersion="3" />

    <!--
      Local feed — useful during active package development to test a package
      locally before publishing. Point this at a folder on disk and drop
      .nupkg files there. Disabled by default; uncomment when needed.

      NB: Never commit a local path that only exists on your machine without
      the 'disabled' flag — it will break every CI run.
    -->
    <!--
    <add key="local-dev"
         value="C:\LocalNuGet"
         disabled="true" />
    -->
  </packageSources>

  <!--
    Disable the local feed explicitly so it can't be accidentally enabled
    by a machine-level config override.
  -->
  <disabledPackageSources>
    <clear></clear>
  </disabledPackageSources>

  <packageSourceMapping>
    <!--
      Package Source Mapping — tells NuGet exactly which feed each package
      comes from. Prevents dependency confusion attacks where a malicious
      package on nuget.org shadows one of your private packages.

      Pattern rules:
        *          matches any package ID
        Prefix.*   matches any package starting with that prefix

      Keep your internal package prefix(es) mapped exclusively to the
      github feed, and everything else to nuget.org.
    -->

    <!-- Your internal packages — only ever resolved from GitHub Packages -->
    <packageSource name="github">
      <!--
        Replace 'AStarDevelopment.' with your actual package ID prefix.
        Add one pattern per prefix if you use multiple naming conventions.
      -->
      <package pattern="AStarDevelopment.*" />
    </packageSource>

    <!-- Everything else comes from nuget.org -->
    <packageSource name="nuget.org">
      <package pattern="*" />
    </packageSource>

  </packageSourceMapping>

  <config>
    <!--
      Store the global NuGet cache outside the repo so it is shared across
      all solutions on the machine and never accidentally committed.
      This is the default location — stated explicitly for clarity.
    -->
    <add key="globalPackagesFolder" value="~/.nuget/packages" />

    <!--
      Parallel restore — speeds up restore significantly in a large repo.
      8 is a sensible ceiling; go higher only if your network can sustain it.
    -->
    <add key="maxHttpRequestsPerSource" value="8" />
  </config>

</configuration>
