<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>true</IsPackable>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Title>AStar.Dev.Test.Helpers.Minimal.Api</Title>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Description>Contains some helper methods to make testing of the minimal APIs easier.</Description>
        <PackageProjectUrl>https://github.com/astar-development/astar-dev-mono/tree/main/packages/test-helpers</PackageProjectUrl>
        <PackageTags>Minimap API Testing</PackageTags>
        <PackageReleaseNotes>Initial creation.</PackageReleaseNotes>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <DocumentationFile>$(AssemblyName).xml</DocumentationFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Asp.Versioning.Mvc" />
        <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\astar.png" Pack="True" PackagePath="/" Link="astar.png"/>
        <None Include="..\..\Readme.md" Pack="True" PackagePath="/" Link="Readme.md"/>
    </ItemGroup>

</Project>
