<Project Sdk="Microsoft.NET.Sdk">

  <!--
    AStar.Dev.Conflict.Resolution
    ══════════════════════════════
    Conflict detection and resolution strategies for the sync engine.
    TFM, nullable, analysers, IsPackable, GenerateDocumentationFile,
    and SourceLink are all inherited from packages/Directory.Build.props.
  -->

  <PropertyGroup>
    <Description>Conflict detection and resolution strategies used by the AStar Dev sync engine when concurrent edits are detected on local and remote files.</Description>
    <PackageTags>conflict;resolution;sync;onedrive;astar;astardevelopment</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Title>AStar Dev Conflict Resolution</Title>
    <PackageProjectUrl>https://github.com/astar-development/astar-dev-mono/tree/main/packages/core/astar-dev-conflict-resolution</PackageProjectUrl>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <DocumentationFile>$(AssemblyName).xml</DocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.Wrappers" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../functional/AStar.Dev.Functional.Extensions/AStar.Dev.Functional.Extensions.csproj" />
    <ProjectReference Include="../../logging/AStar.Dev.Logging.Extensions/AStar.Dev.Logging.Extensions.csproj" />
  </ItemGroup>

</Project>
