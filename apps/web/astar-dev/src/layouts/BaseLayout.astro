---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.vue';
import '../styles/themes.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Senior .NET Engineer & Architect — architecture, pipelines, observability, and open source packages.',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://astar.dev');

// App Insights connection string — optional; omitted if env var not set
const appInsightsConnString = import.meta.env.PUBLIC_APPINSIGHTS_CONNECTION_STRING ?? '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- No-flash theme script: must be inline, before stylesheets, synchronous -->
    <script is:inline>
      (function () {
        var valid = ['dark', 'light', 'metal', 'polished'];
        var stored;
        try { stored = localStorage.getItem('theme'); } catch (_) {}
        var theme = valid.indexOf(stored) !== -1 ? stored : 'dark';
        document.documentElement.className = 'theme-' + theme;
      })();
    </script>

    <title>{title} | AStar Development</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | AStar Development`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />

    <!-- Favicon placeholder (replace with real assets) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Named slot for page-specific head elements (e.g. blog OG tags) -->
    <slot name="head" />
  </head>

  <body>
    <!-- Skip to main content (first focusable element — WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Nav />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <CookieConsent client:load />

    <!-- Cookie preferences reset + App Insights conditional loader -->
    <script is:inline define:vars={{ appInsightsConnString }}>
      (function () {
        var CONSENT_KEY = 'cookie-consent';

        // Wire up the footer "Cookie preferences" button
        document.addEventListener('click', function (e) {
          if (e.target && e.target.id === 'js-cookie-pref') {
            try { localStorage.removeItem(CONSENT_KEY); } catch (_) {}
            window.location.reload();
          }
        });

        // Load App Insights only when the user has accepted analytics cookies
        function loadAppInsights() {
          if (!appInsightsConnString) return;
          var script = document.createElement('script');
          script.src = 'https://js.monitor.azure.com/scripts/b/ai.2.min.js';
          script.onload = function () {
            var ai = window.appInsights || (window.appInsights = {});
            ai.config = { connectionString: appInsightsConnString, disableCookiesUsage: false, enableAutoRouteTracking: false };
            if (window.Microsoft && window.Microsoft.ApplicationInsights) {
              var sdk = new window.Microsoft.ApplicationInsights.ApplicationInsights({ config: ai.config });
              sdk.loadAppInsights();
              sdk.trackPageView();
              window.appInsights = sdk;
            }
          };
          document.head.appendChild(script);
        }

        // Check current consent state
        try {
          var stored = localStorage.getItem(CONSENT_KEY);
          if (stored) {
            var prefs = JSON.parse(stored);
            if (prefs && prefs.analytics === true) loadAppInsights();
          }
        } catch (_) {}

        // Also listen for consent events dispatched by CookieConsent.vue
        window.addEventListener('cookie-consent-accepted', loadAppInsights);
      })();
    </script>
  </body>
</html>

<style is:global>
  /* Smooth theme transition on all tokenised properties */
  *, *::before, *::after {
    transition-property: background-color, border-color, color, fill, stroke;
    transition-duration: 0.25s;
    transition-timing-function: ease;
  }
</style>
