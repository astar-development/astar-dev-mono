---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  summary: string;
  tags: string[];
  readingTime: number;
}

const { title, date, summary, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const isoDate = date.toISOString().split('T')[0];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://astar.dev');
---

<BaseLayout title={title} description={summary}>
  <Fragment slot="head">
    <!-- Blog-specific Open Graph overrides -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={isoDate} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | AStar Development`} />
    <meta name="twitter:description" content={summary} />
  </Fragment>

  <div class="reading-column">
    <a href="/blog" class="back-link">&larr; Back to blog</a>

    <span class="content-type-pill">Blog Post</span>

    <h1>{title}</h1>

    <div class="post-meta">
      <time datetime={isoDate} class="meta-item">{formattedDate}</time>
      <span class="meta-sep" aria-hidden="true">&middot;</span>
      <span class="meta-item">{readingTime} min read</span>
    </div>

    <ul class="tag-list" role="list">
      {tags.map((tag) => (
        <li>
          <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
        </li>
      ))}
    </ul>

    <hr class="content-divider" />

    <article class="post-content">
      <slot />
    </article>

    <hr class="content-divider" />

    <a href="/blog" class="back-link">&larr; Back to blog</a>
  </div>
</BaseLayout>

<style is:global>
  .post-content h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 40px;
    margin-bottom: 12px;
    transition: color 0.25s;
  }

  .post-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 28px;
    margin-bottom: 10px;
    transition: color 0.25s;
  }

  .post-content p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 20px;
    transition: color 0.25s;
  }

  .post-content ul,
  .post-content ol {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 20px;
    padding-left: 24px;
    transition: color 0.25s;
  }

  .post-content li {
    margin-bottom: 6px;
  }

  .post-content blockquote {
    border-left: 3px solid var(--accent);
    margin: 0 0 20px;
    padding: 4px 0 4px 20px;
    color: var(--text-muted);
    font-style: italic;
    transition: border-color 0.25s, color 0.25s;
  }

  .post-content pre {
    background: var(--terminal-bg);
    border-radius: 8px;
    padding: 20px 24px;
    margin-bottom: 24px;
    overflow-x: auto;
    transition: background-color 0.25s;
  }

  .post-content pre code {
    font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--terminal-text);
    background: none;
    padding: 0;
    transition: color 0.25s;
  }

  .post-content :not(pre) > code {
    font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
    font-size: 0.85em;
    background: var(--terminal-bg);
    color: var(--terminal-accent);
    padding: 2px 6px;
    border-radius: 4px;
    transition: background-color 0.25s, color 0.25s;
  }

  .post-content a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.25s;
  }

  .post-content a:hover {
    text-decoration: underline;
  }

  .post-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
    transition: border-color 0.25s;
  }
</style>

<style>
  .reading-column {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .back-link {
    display: inline-block;
    color: var(--accent);
    font-size: 0.9rem;
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.25s;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .back-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .content-type-pill {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.72rem;
    border-radius: 999px;
    padding: 2px 8px;
    margin-bottom: 16px;
    transition: border-color 0.25s, color 0.25s;
  }

  h1 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
    line-height: 1.25;
    transition: color 0.25s;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .meta-item {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.25s;
  }

  .meta-sep {
    color: var(--text-muted);
    transition: color 0.25s;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
  }

  .tag-pill {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    border-radius: 999px;
    padding: 3px 10px;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
  }

  .tag-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .tag-pill:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 999px;
  }

  .content-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
    transition: border-color 0.25s;
  }
</style>
