---
import ThemeSwitcher from './ThemeSwitcher.vue';
import MobileMenu from './MobileMenu.vue';

const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com';
const nugetUrl = import.meta.env.PUBLIC_NUGET_URL ?? 'https://www.nuget.org';

const { pathname } = Astro.url;

interface NavLink {
  href: string;
  label: string;
}

const links: NavLink[] = [
  { href: '/',             label: 'Home' },
  { href: '/packages',     label: 'Packages' },
  { href: '/blog',         label: 'Blog' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/contact',      label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<nav aria-label="Main navigation" class="nav">
  <div class="nav-inner">

    <!-- Left zone: brand -->
    <a href="/" class="brand" aria-label="AStar Development — home">
      <svg
        class="brand-logo"
        width="40"
        height="40"
        viewBox="0 0 40 40"
        fill="none"
        aria-hidden="true"
        focusable="false"
      >
        <rect width="40" height="40" rx="8" fill="var(--accent)" opacity="0.15"/>
        <path d="M20 6L34 30H6L20 6Z" fill="var(--accent)" opacity="0.9"/>
        <path d="M20 14L29 30H11L20 14Z" fill="var(--surface-base)" opacity="0.7"/>
      </svg>
      <div class="brand-text">
        <span class="brand-name">AStar Development</span>
        <span class="brand-tagline">Software Architecture &amp; Development</span>
      </div>
    </a>

    <!-- Centre zone: page links (desktop only) -->
    <ul class="nav-links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { 'nav-link--active': isActive(href) }]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right zone: theme switcher + external links -->
    <div class="nav-actions">
      <ThemeSwitcher client:load />

      <div class="nav-separator" aria-hidden="true"></div>

      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile, opens in new tab"
        class="nav-icon-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>

      <a
        href={nugetUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="NuGet profile, opens in new tab"
        class="nav-icon-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zm-9 9.5A2.5 2.5 0 0 0 .5 14v7A2.5 2.5 0 0 0 3 23.5h7A2.5 2.5 0 0 0 12.5 21v-7A2.5 2.5 0 0 0 10 11.5H3zm11 0A2.5 2.5 0 0 0 11.5 14v7A2.5 2.5 0 0 0 14 23.5h7A2.5 2.5 0 0 0 23.5 21v-7A2.5 2.5 0 0 0 21 11.5h-7z"/>
        </svg>
      </a>

      <!-- Mobile hamburger (replaces centre + right zones on mobile) -->
      <MobileMenu client:load links={links} githubUrl={githubUrl} nugetUrl={nugetUrl} currentPathname={pathname} />
    </div>

  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-border);
    height: 64px;
    transition: background-color 0.25s, border-color 0.25s;
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-logo {
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .brand-name {
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.2;
    transition: color 0.25s;
  }

  .brand-tagline {
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1.2;
    transition: color 0.25s;
  }

  /* Page links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .nav-links li {
    height: 100%;
    display: flex;
    align-items: stretch;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0 12px;
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 3px solid transparent;
    transition: opacity 0.15s, border-color 0.15s, color 0.25s;
  }

  .nav-link:hover {
    opacity: 0.75;
  }

  .nav-link--active {
    border-bottom-color: var(--active-indicator);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -3px;
    border-radius: 2px;
  }

  /* Right zone */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .nav-separator {
    width: 1px;
    height: 20px;
    background: var(--border);
    transition: background-color 0.25s;
  }

  .nav-icon-link {
    display: flex;
    align-items: center;
    padding: 4px;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.2s;
  }

  .nav-icon-link:hover {
    color: var(--accent);
  }

  .nav-icon-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Mobile: hide desktop links and icon links, show only hamburger */
  @media (max-width: 767px) {
    .nav {
      height: 56px;
    }

    .nav-links,
    .nav-separator,
    .nav-icon-link {
      display: none;
    }

    .brand-tagline {
      display: none;
    }
  }
</style>
