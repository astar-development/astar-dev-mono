---
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com';
const nugetUrl = import.meta.env.PUBLIC_NUGET_URL ?? 'https://www.nuget.org';
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="copy">&copy; {year} AStar Development. All rights reserved.</p>

    <div class="footer-links">
      <a href="/privacy" class="footer-link">Privacy Policy</a>
      <button type="button" class="footer-link cookie-pref-btn" id="js-cookie-pref">Cookie preferences</button>
    </div>

    <div class="icon-links">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile, opens in new tab"
        class="icon-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>

      <a
        href={nugetUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="NuGet profile, opens in new tab"
        class="icon-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zm-9 9.5A2.5 2.5 0 0 0 0.5 14v7A2.5 2.5 0 0 0 3 23.5h7A2.5 2.5 0 0 0 12.5 21v-7A2.5 2.5 0 0 0 10 11.5H3zm11 0A2.5 2.5 0 0 0 11.5 14v7A2.5 2.5 0 0 0 14 23.5h7A2.5 2.5 0 0 0 23.5 21v-7A2.5 2.5 0 0 0 21 11.5h-7z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--footer-bg);
    border-top: 1px solid var(--section-border);
    padding: 24px;
    transition: background-color 0.25s, border-color 0.25s;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .copy {
    color: var(--text-muted);
    font-size: 0.83rem;
    transition: color 0.25s;
  }

  .footer-links {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-link {
    color: var(--text-muted);
    font-size: 0.83rem;
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.25s;
  }

  .footer-link:hover {
    color: var(--text);
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .icon-links {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .icon-link {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .icon-link:hover {
    color: var(--accent);
  }

  .icon-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 3px;
    border-radius: 4px;
  }

  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }
  }
</style>
