PUBLIC_AVAILABLE_FOR_CONTRACTS=true

PUBLIC_GITHUB_URL=https://github.com/astar-development
PUBLIC_NUGET_URL=https://www.nuget.org/profiles/AStar-Development

MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
CONTACT_EMAIL=
MAILJET_FROM_EMAIL=

# Server-side telemetry (Node SDK — read at runtime via process.env)
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Client-side telemetry (browser JS SDK — baked in at build time, safe to expose)
PUBLIC_APPINSIGHTS_CONNECTION_STRING=
