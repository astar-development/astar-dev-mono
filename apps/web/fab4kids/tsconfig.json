{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src", "astro.config.ts"],
  "exclude": ["src/__tests__", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
