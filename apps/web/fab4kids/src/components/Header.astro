---
import { SUBJECTS, SUBJECT_LABELS } from '@/lib/constants';
import { ThemeSwitcher } from './ThemeSwitcher.tsx';
import { CartApp } from './CartApp.tsx';
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="fab4kids home">
      <span class="site-header__logo-text">fab4kids</span>
    </a>

    <button
      class="site-header__hamburger"
      aria-controls="primary-nav"
      aria-expanded="false"
      aria-label="Toggle navigation"
      id="hamburger-btn"
    >
      <span class="site-header__bar"></span>
      <span class="site-header__bar"></span>
      <span class="site-header__bar"></span>
    </button>

    <nav class="site-header__nav" id="primary-nav" aria-label="Primary navigation">
      <ul class="site-header__nav-list" role="list">
        {SUBJECTS.map((subject) => (
          <li>
            <a href={`/${subject}`} class="site-header__nav-link">
              {SUBJECT_LABELS[subject]}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <form class="site-header__search" action="/search" method="get" role="search">
      <input
        name="q"
        type="search"
        placeholder="Search resources..."
        aria-label="Search"
        class="site-header__search-input"
      />
      <button type="submit" class="site-header__search-btn" aria-label="Submit search">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>

    <div class="site-header__actions">
      <CartApp client:load />
      <ThemeSwitcher client:load />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .site-header__logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-header__logo-text {
    font-family: var(--font-family-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .site-header__nav {
    flex: 1;
  }

  .site-header__nav-list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
  }

  .site-header__nav-link {
    display: block;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .site-header__nav-link:hover {
    background: var(--color-bg);
    color: var(--color-primary);
  }

  .site-header__search {
    display: flex;
    align-items: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .site-header__search-input {
    border: none;
    background: transparent;
    padding: 0.375rem 0.75rem;
    color: var(--color-text);
    width: 14rem;
    outline: none;
  }

  .site-header__search-input::placeholder {
    color: var(--color-text-muted);
  }

  .site-header__search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 0.625rem;
    background: transparent;
    border: none;
    border-left: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .site-header__search-btn:hover {
    color: var(--color-primary);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .site-header__cart-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: var(--radius-md);
    color: var(--color-text);
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .site-header__cart-btn:hover {
    background: var(--color-bg);
    color: var(--color-primary);
  }

  .site-header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    padding: 0.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    margin-left: auto;
  }

  .site-header__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .site-header__hamburger {
      display: flex;
    }

    .site-header__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg-surface);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-md);
    }

    .site-header__nav-list {
      flex-direction: column;
      padding: 0.75rem 1.5rem;
      gap: 0.125rem;
    }

    .site-header__search {
      display: none;
    }

    .site-header__inner {
      flex-wrap: wrap;
      position: relative;
    }

    .site-header__actions {
      order: 3;
    }
  }

  @media (max-width: 768px) {
    .site-header__hamburger:focus + #primary-nav,
    #primary-nav:focus-within {
      display: block;
    }
  }
</style>
