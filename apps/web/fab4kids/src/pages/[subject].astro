---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { ProductCard } from '@/components/ProductCard.tsx';
import { getProductsBySubject } from '@/lib/sanity.ts';
import { SUBJECTS, SUBJECT_LABELS, KEY_STAGES, KEY_STAGE_LABELS } from '@/lib/constants.ts';
import type { Subject } from '@/types/index.ts';

export const prerender = true;

export const getStaticPaths = (async () => {
  return SUBJECTS.map((subject) => ({ params: { subject } }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { subject } = Astro.params as { subject: Subject };
const products = await getProductsBySubject(subject);
const subjectLabel = SUBJECT_LABELS[subject];
---

<PageLayout
  title={`${subjectLabel} Resources`}
  description={`Browse all ${subjectLabel} resources for KS1–KS4 on fab4kids.`}
>
  <section class="hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-current="page">{subjectLabel}</li>
        </ol>
      </nav>
      <h1 class="hero__title">{subjectLabel} Resources</h1>
      <p class="hero__subtitle">Browse all {subjectLabel} resources for KS1–KS4.</p>
    </div>
  </section>

  <section class="filter-bar">
    <div class="container">
      <nav aria-label="Filter by key stage">
        <ul class="ks-tabs">
          <li>
            <a href={`/${subject}`} class="ks-tab ks-tab--active" aria-current="page">All</a>
          </li>
          {KEY_STAGES.map((ks) => (
            <li>
              <a href={`/${subject}/${ks}`} class="ks-tab">{KEY_STAGE_LABELS[ks]}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>

  <section class="catalogue">
    <div class="container">
      {products.length === 0 ? (
        <div class="empty-state">
          <p>No {subjectLabel} resources available yet. Check back soon!</p>
          <a href="/" class="btn btn--secondary">Back to home</a>
        </div>
      ) : (
        <div class="product-grid">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .container {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .hero {
    padding-block: 3rem 2rem;
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .breadcrumb li + li::before {
    content: '›';
    margin-right: 0.5rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .hero__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .hero__subtitle {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }

  .filter-bar {
    padding-block: 1.25rem;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .ks-tabs {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    flex-wrap: wrap;
  }

  .ks-tab {
    display: inline-flex;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    background: var(--color-bg-surface);
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .ks-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .ks-tab--active {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
    border-color: var(--color-primary);
  }

  .ks-tab--active:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: var(--color-primary-contrast);
  }

  .catalogue {
    padding-block: 2.5rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding-block: 4rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .btn--secondary:hover {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
  }
</style>
