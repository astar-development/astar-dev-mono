  description="Terms and conditions for using fab4kids and purchasing educational resources."
>
  <article class="legal-page">
    <h1>Terms and Conditions</h1>
    <p class="legal-meta">Last updated: April 2026</p>

    <p>
      Please read these terms carefully before purchasing from fab4kids.
