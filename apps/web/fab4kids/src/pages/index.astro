---
import PageLayout from '@/layouts/PageLayout.astro';
import { SUBJECTS, SUBJECT_LABELS } from '@/lib/constants.ts';
import { NewsletterForm } from '@/components/NewsletterForm.tsx';

export const prerender = true;

const SUBJECT_DESCRIPTIONS: Record<(typeof SUBJECTS)[number], string> = {
  maths: 'Number, algebra, geometry, statistics and problem-solving resources.',
  english: 'Reading, writing, grammar, punctuation and comprehension activities.',
  science: 'Biology, chemistry, physics and working scientifically resources.',
  history: 'Primary and secondary sources, timelines and in-depth topic studies.',
  geography: 'Maps, fieldwork, physical and human geography investigations.',
};

const SUBJECT_EMOJIS: Record<(typeof SUBJECTS)[number], string> = {
  maths: '🔢',
  english: '📚',
  science: '🔬',
  history: '🏛️',
  geography: '🌍',
};
---

<PageLayout
  title="Quality resources for every child"
  description="Curriculum-aligned PDFs and Word documents for KS1–KS4. Maths, English, Science, History and Geography."
>
  <section class="hero">
    <div class="container">
      <h1 class="hero__headline">Quality resources for every child</h1>
      <p class="hero__subtitle">Curriculum-aligned PDFs and Word documents for KS1–KS4</p>
      <div class="hero__ctas">
        <a href="/maths" class="btn btn--primary">Browse resources</a>
        <a href="/search" class="btn btn--secondary">Search</a>
      </div>
    </div>
  </section>

  <section class="subjects">
    <div class="container">
      <h2 class="section-title">Browse by subject</h2>
      <div class="subject-grid">
        {SUBJECTS.map((subject) => (
          <a href={`/${subject}`} class="subject-card">
            <span class="subject-card__icon" aria-hidden="true">{SUBJECT_EMOJIS[subject]}</span>
            <h3 class="subject-card__label">{SUBJECT_LABELS[subject]}</h3>
            <p class="subject-card__description">{SUBJECT_DESCRIPTIONS[subject]}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="newsletter">
    <div class="container">
      <h2 class="section-title">Stay up to date</h2>
      <p class="newsletter__subtitle">Get notified when new resources are added.</p>
      <div id="newsletter">
        <NewsletterForm client:load />
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .container {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .hero {
    padding-block: 5rem 4rem;
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  .hero__headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 40rem;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
    border: 2px solid transparent;
  }

  .btn--primary {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
  }

  .btn--primary:hover {
    background: var(--color-primary-hover);
    color: var(--color-primary-contrast);
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .btn--secondary:hover {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
  }

  .subjects {
    padding-block: 4rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2rem;
    text-align: center;
  }

  .subject-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1.5rem;
  }

  .subject-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .subject-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .subject-card__icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .subject-card__label {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .subject-card__description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .newsletter {
    padding-block: 4rem;
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .newsletter__subtitle {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .newsletter__placeholder {
    display: inline-block;
    padding: 1rem 2rem;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
