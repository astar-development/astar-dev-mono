---
import '@/styles/global.css';
import { CookieBanner } from '@/components/CookieBanner.tsx';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const appInsightsConnString = import.meta.env.PUBLIC_APPINSIGHTS_CONNECTION_STRING ?? '';
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | fab4kids</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | fab4kids`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const VALID_THEMES = ['light', 'dark', 'colourful'];
        const stored = localStorage.getItem('fab4kids-theme');
        let theme;
        if (stored !== null && VALID_THEMES.includes(stored)) {
          theme = stored;
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          theme = 'dark';
        } else {
          theme = 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <CookieBanner client:load />
    <script is:inline define:vars={{ appInsightsConnString }}>
      (function () {
        var CONSENT_KEY = 'fab4kids-cookie-consent';
        var appInsightsLoading = false;

        function loadStripe() {
          var s = document.createElement('script');
          s.src = 'https://js.stripe.com/v3/';
          s.async = true;
          document.head.appendChild(s);
        }

        function loadAppInsights(withCookies) {
          if (!appInsightsConnString) return;
          if (window.appInsights && window.appInsights.__loaded) {
            if (withCookies && window.appInsights.__cookieless) {
              window.appInsights.config.isCookieUseDisabled = false;
              window.appInsights.__cookieless = false;
            }
            return;
          }
          if (appInsightsLoading) return;
          appInsightsLoading = true;
          var script = document.createElement('script');
          script.src = 'https://js.monitor.azure.com/scripts/b/ai.2.min.js';
          script.onload = function () {
            if (!window.Microsoft || !window.Microsoft.ApplicationInsights) return;
            var sdk = new window.Microsoft.ApplicationInsights.ApplicationInsights({
              config: {
                connectionString: appInsightsConnString,
                disableCookiesUsage: !withCookies,
                enableAutoRouteTracking: false,
              }
            });
            sdk.loadAppInsights();
            sdk.trackPageView();
            sdk.__loaded = true;
            sdk.__cookieless = !withCookies;
            window.appInsights = sdk;
          };
          document.head.appendChild(script);
        }

        var alreadyAccepted = localStorage.getItem(CONSENT_KEY) === 'accepted';
        loadAppInsights(alreadyAccepted);
        if (alreadyAccepted) loadStripe();

        window.addEventListener('cookie-consent-accepted', function () {
          loadAppInsights(true);
          loadStripe();
        });
      })();
    </script>
  </body>
</html>
