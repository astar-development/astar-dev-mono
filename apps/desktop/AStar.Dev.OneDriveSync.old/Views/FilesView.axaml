<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AStar.Dev.OneDriveSync.old.ViewModels"
             xmlns:controls="clr-namespace:AStar.Dev.OneDriveSync.old.Controls"
             xmlns:loc="clr-namespace:AStar.Dev.OneDriveSync.old.Localisation"
             x:Class="AStar.Dev.OneDriveSync.old.Views.FilesView"
             x:DataType="vm:FilesViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Tab strip ── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                Background="{DynamicResource BackgroundSecondaryBrush}">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Tabs}"
                              x:Name="TabStrip">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccountFilesViewModel">

                            <Button Background="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Padding="16,0"
                                    Height="40"
                                    Click="OnTabClick"
                                    Tag="{Binding AccountId}">

                                <Button.BorderBrush>
                                    <SolidColorBrush Color="{Binding IsActiveTab,
                                        Converter={StaticResource BoolToAccentConverter}}"/>
                                </Button.BorderBrush>

                                <StackPanel Orientation="Horizontal" Spacing="8">

                                    <Ellipse Width="8" Height="8"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding AccentColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Text="{Binding TabLabel}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                </StackPanel>
                            </Button>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── No accounts placeholder ── -->
        <StackPanel Grid.Row="1"
                    IsVisible="{Binding HasNoAccounts}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <TextBlock Text="{loc:Localize Files_NoAccountsTitle}"
                       FontSize="{StaticResource FontSizeLg}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{loc:Localize Files_NoAccountsMessage}"
                       FontSize="{StaticResource FontSizeMd}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Active tab content ── -->
        <Grid Grid.Row="1"
              IsVisible="{Binding HasTabs}">

            <ContentControl Content="{Binding ActiveTab}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:AccountFilesViewModel">

                        <Grid>

                            <!-- Loading -->
                            <StackPanel IsVisible="{Binding IsLoading}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <ProgressBar IsIndeterminate="True"
                                             Width="200" Height="2"
                                             Foreground="{DynamicResource TextAccentBrush}"
                                             Background="Transparent"/>
                                <TextBlock Text="{loc:Localize Files_LoadingFolders}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Error -->
                            <StackPanel IsVisible="{Binding HasLoadError}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="{loc:Localize Files_CouldNotLoadFolders}"
                                           FontSize="{StaticResource FontSizeMd}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding LoadError}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource StatusErrorBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="360"
                                           TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Folder tree -->
                            <ScrollViewer IsVisible="{Binding !IsLoading}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="12,8">
                                <ItemsControl ItemsSource="{Binding RootFolders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:FolderTreeNodeViewModel">
                                            <controls:FolderTreeItemView/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </Grid>

                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </Grid>

    </Grid>

</UserControl>
