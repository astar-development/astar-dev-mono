<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AStar.Dev.OneDriveSync.Features.Conflicts"
             xmlns:loc="using:AStar.Dev.OneDriveSync.Infrastructure.Localisation"
             x:Class="AStar.Dev.OneDriveSync.Features.Conflicts.ConflictsView"
             x:DataType="vm:ConflictsViewModel">

    <DockPanel>

        <Border DockPanel.Dock="Top" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding SelectAllCommand}"
                        Content="{loc:Localise Conflicts_SelectAll}"/>
                <Button Command="{Binding LocalWinsCommand}"
                        Content="{loc:Localise Conflicts_LocalWins}"/>
                <Button Command="{Binding RemoteWinsCommand}"
                        Content="{loc:Localise Conflicts_RemoteWins}"/>
                <Button Command="{Binding KeepBothCommand}"
                        Content="{loc:Localise Conflicts_KeepBoth}"/>
                <Button Command="{Binding SkipCommand}"
                        Content="{loc:Localise Conflicts_Skip}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ErrorBannerBrush}"
                Padding="12,6"
                IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <ItemsControl ItemsSource="{Binding Conflicts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ConflictItemViewModel">
                    <Border Padding="12,8" BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource BorderSubtleBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding FileName}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding FilePath}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AccountDisplayName}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LocalLastModified}"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding RemoteLastModified}"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4"
                                       Text="{Binding ConflictType}"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextAccentBrush}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>

</UserControl>
