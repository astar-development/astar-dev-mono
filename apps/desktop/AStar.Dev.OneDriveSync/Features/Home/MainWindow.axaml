<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AStar.Dev.OneDriveSync.Features.Home"
        xmlns:shell="using:AStar.Dev.OneDriveSync.Infrastructure.Shell"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="AStar.Dev.OneDriveSync.Features.Home.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://AStar.Dev.OneDriveSync/Assets/astar.ico"
        Title="AStar OneDrive Sync"
        MinWidth="900" MinHeight="600">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="200,*">

        <!-- Startup error banner — spans the full width above both columns -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#C0392B"
                Padding="12,8"
                IsVisible="{Binding HasStartupError}">
            <TextBlock Text="{Binding StartupErrorMessage}"
                       Foreground="White"
                       FontWeight="SemiBold" />
        </Border>

        <!-- Navigation rail -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,1,0"
                IsEnabled="{Binding IsNavEnabled}">
            <ItemsControl ItemsSource="{Binding NavItems}" Margin="0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="shell:NavItemViewModel">
                        <Button Content="{Binding Label}"
                                IsEnabled="{Binding IsFeatureEnabled}"
                                ToolTip.Tip="{Binding Tooltip}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{Binding Section}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Margin="4,2"
                                Padding="12,8" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- Loading overlay — visible while startup tasks are running -->
            <StackPanel IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="240" />
                <TextBlock Text="Initialising…"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Active feature view — visible once startup completes -->
            <ContentControl Content="{Binding ActiveView}"
                            IsVisible="{Binding IsNavEnabled}" />
        </Grid>

    </Grid>
</Window>
