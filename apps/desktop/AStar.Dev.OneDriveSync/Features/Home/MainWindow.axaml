<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AStar.Dev.OneDriveSync.Features.Home"
        xmlns:shell="using:AStar.Dev.OneDriveSync.Infrastructure.Shell"
        xmlns:loc="using:AStar.Dev.OneDriveSync.Infrastructure.Localisation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="AStar.Dev.OneDriveSync.Features.Home.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://AStar.Dev.OneDriveSync/Assets/astar.ico"
        Title="{loc:Localise MainWindow_Title}"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BackgroundPrimaryBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- Startup error banner — spans the full width above all columns -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundErrorBrush}"
                Padding="12,8"
                IsVisible="{Binding HasStartupError}">
            <TextBlock Text="{Binding StartupErrorMessage}"
                       Foreground="{DynamicResource TextOnErrorBrush}"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Working area: icon rail + content -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

            <!-- Icon rail -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BackgroundRailBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    Width="{StaticResource IconRailWidth}"
                    IsEnabled="{Binding IsNavEnabled}">
                <DockPanel LastChildFill="False">

                    <!-- Top nav section: Dashboard, Accounts, Activity, Conflicts, Log Viewer -->
                    <ItemsControl DockPanel.Dock="Top"
                                  ItemsSource="{Binding TopNavItems}"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="shell:NavItemViewModel">
                                <shell:IconRailButton
                                    IconPath="{Binding IconPath}"
                                    IsActive="{Binding IsActive}"
                                    IsEnabled="{Binding IsFeatureEnabled}"
                                    TooltipLabel="{Binding Tooltip}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="{Binding Section}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom nav section: Settings, Help, About -->
                    <ItemsControl DockPanel.Dock="Bottom"
                                  ItemsSource="{Binding BottomNavItems}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="shell:NavItemViewModel">
                                <shell:IconRailButton
                                    IconPath="{Binding IconPath}"
                                    IsActive="{Binding IsActive}"
                                    IsEnabled="{Binding IsFeatureEnabled}"
                                    TooltipLabel="{Binding Tooltip}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="{Binding Section}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </DockPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Column="1">

                <!-- Loading overlay — visible while startup tasks are running -->
                <StackPanel IsVisible="{Binding IsLoading}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <ProgressBar IsIndeterminate="True" Width="240"/>
                    <TextBlock Text="{loc:Localise MainWindow_Loading}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Active feature view — visible once startup completes -->
                <ContentControl Content="{Binding ActiveView}"
                                IsVisible="{Binding IsNavEnabled}"/>

            </Grid>

        </Grid>

    </Grid>
</Window>
