<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AStar.Dev.OneDriveSync.Features.About"
             xmlns:loc="using:AStar.Dev.OneDriveSync.Infrastructure.Localisation"
             x:Class="AStar.Dev.OneDriveSync.Features.About.AboutView"
             x:DataType="vm:AboutViewModel">
    <TextBlock Text="{loc:Localise About_ComingSoon}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
</UserControl>
