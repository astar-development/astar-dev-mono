<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="local:OnboardingViewModel"
             xmlns:local="using:AStar.Dev.OneDriveSync.Features.Onboarding"
             x:Class="AStar.Dev.OneDriveSync.Features.Onboarding.OnboardingView">
    <StackPanel Spacing="16" Padding="24">
        <TextBlock Text="Welcome to OneDrive Sync" FontSize="24" FontWeight="Bold" />
        
        <TextBlock Text="Keep your OneDrive files in sync with your computer. Choose account settings below to get started."
                   TextWrapping="Wrap" />
        
        <!-- User Type Selection -->
        <StackPanel Spacing="12">
            <TextBlock Text="User Type" FontWeight="Bold" />
            
            <StackPanel Spacing="8">
                <RadioButton GroupName="UserType" Content="Casual (default, simple settings)" />
                <RadioButton GroupName="UserType" Content="Power User (advanced settings &amp; tuning)" />
            </StackPanel>
        </StackPanel>
        
        <!-- Action Buttons -->
        <StackPanel Spacing="12" Margin="0,24,0,0">
            <Button Content="Add my first account" />
            <Button Content="Skip" />
        </StackPanel>
        
        <!-- Help Link -->
        <StackPanel HorizontalAlignment="Center" Margin="0,24,0,0">
            <Button Content="Help &amp; Documentation" />
        </StackPanel>
    </StackPanel>
</UserControl>
