<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AStar.Dev.OneDriveSync.Features.Activity"
             xmlns:loc="using:AStar.Dev.OneDriveSync.Infrastructure.Localisation"
             x:Class="AStar.Dev.OneDriveSync.Features.Activity.ActivityView"
             x:DataType="vm:ActivityViewModel">

    <Panel>

        <TextBlock Text="{loc:Localise Activity_EmptyState}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   IsVisible="{Binding IsEmpty}" />

        <ScrollViewer IsVisible="{Binding !IsEmpty}">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ActivityItemViewModel">
                        <Border Padding="12,8"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource BorderSubtleBrush}">
                            <Grid ColumnDefinitions="140,80,*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp}"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ActionType}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextAccentBrush}" />
                                <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding FilePath}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding AccountId}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Panel>

</UserControl>
