<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AStar.Dev.OneDriveSync.App"
             xmlns:local="using:AStar.Dev.OneDriveSync.Infrastructure"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AStar.Dev.OneDriveSync/Infrastructure/Shell/Themes/Base.axaml"/>
                <ResourceInclude Source="avares://AStar.Dev.OneDriveSync/Infrastructure/Shell/Themes/ColourPalette.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
