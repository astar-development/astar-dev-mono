<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AStar.Dev.OneDriveSync.ViewModels"
             xmlns:loc="clr-namespace:AStar.Dev.OneDriveSync.Localisation"
             x:Class="AStar.Dev.OneDriveSync.Views.LogViewerView"
             x:DataType="vm:LogViewerViewModel">
    <!--
        LG-03: Hidden log viewer, opened via CTRL+SHIFT+ALT+L from anywhere in the app.
        LG-04: Shows all errors across all accounts, unified, scrollable, filterable.
    -->

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Background="{DynamicResource BackgroundPrimaryBrush}">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="16,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                Background="{DynamicResource BackgroundSecondaryBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Localize LogViewer_Title}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Localize LogViewer_Subtitle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                        Padding="8,4"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Command="{Binding CloseCommand}"
                        ToolTip.Tip="{loc:Localize LogViewer_CloseTooltip}"/>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                Background="{DynamicResource BackgroundSecondaryBrush}">
            <Grid ColumnDefinitions="*,12,Auto,8,Auto,8,Auto">

                <!-- Search box -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText}"
                         Watermark="{loc:Localize LogViewer_FilterWatermark}"
                         FontSize="{StaticResource FontSizeSm}"
                         CornerRadius="{StaticResource RadiusMd}"/>

                <!-- Account filter (LG-04) -->
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AccountLabels}"
                          SelectedItem="{Binding SelectedAccount}"
                          MinWidth="120"
                          FontSize="{StaticResource FontSizeSm}"
                          CornerRadius="{StaticResource RadiusMd}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Level filter chips -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="4">
                    <Button Content="{loc:Localize LogViewer_FilterAll}"
                            Padding="8,3"
                            CornerRadius="{StaticResource RadiusSm}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            FontSize="{StaticResource FontSizeXs}"
                            Command="{Binding ShowAllCommand}"/>
                    <Button Content="{loc:Localize LogViewer_FilterErrors}"
                            Padding="8,3"
                            CornerRadius="{StaticResource RadiusSm}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            FontSize="{StaticResource FontSizeXs}"
                            Command="{Binding ShowErrorsCommand}"/>
                    <Button Content="{loc:Localize LogViewer_FilterWarnings}"
                            Padding="8,3"
                            CornerRadius="{StaticResource RadiusSm}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            FontSize="{StaticResource FontSizeXs}"
                            Command="{Binding ShowWarningsCommand}"/>
                    <Button Content="{loc:Localize LogViewer_FilterDebug}"
                            Padding="8,3"
                            CornerRadius="{StaticResource RadiusSm}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            FontSize="{StaticResource FontSizeXs}"
                            Command="{Binding ShowDebugCommand}"/>
                </StackPanel>

                <!-- Clear button -->
                <Button Grid.Column="6"
                        Content="{loc:Localize LogViewer_Clear}"
                        Padding="8,3"
                        CornerRadius="{StaticResource RadiusSm}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        FontSize="{StaticResource FontSizeXs}"
                        Command="{Binding ClearCommand}"/>
            </Grid>
        </Border>

        <!-- Log entries -->
        <Grid Grid.Row="2">

            <!-- Empty state -->
            <StackPanel IsVisible="{Binding !HasEntries}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="{loc:Localize LogViewer_NoEntriesTitle}"
                           FontSize="{StaticResource FontSizeLg}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Localize LogViewer_NoEntriesMessage}"
                           FontSize="{StaticResource FontSizeMd}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Scrollable log list (LG-04) -->
            <ScrollViewer IsVisible="{Binding HasEntries}"
                          VerticalScrollBarVisibility="Auto"
                          x:Name="LogScroller">
                <ItemsControl ItemsSource="{Binding FilteredEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:LogEntryViewModel">
                            <Border BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    Padding="12,6">
                                <Grid ColumnDefinitions="70,8,60,8,80,8,*">

                                    <!-- Timestamp -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TimestampText}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontFamily="Monospace"
                                               VerticalAlignment="Center"/>

                                    <!-- Level badge -->
                                    <Border Grid.Column="2"
                                            Padding="4,1"
                                            CornerRadius="{StaticResource RadiusSm}"
                                            Background="{Binding LevelBackground}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Level}"
                                                   FontSize="{StaticResource FontSizeXs}"
                                                   Foreground="{Binding LevelForeground}"
                                                   FontFamily="Monospace"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Account label -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding AccountLabel}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Message -->
                                    <TextBlock Grid.Column="6"
                                               Text="{Binding Message}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontFamily="Monospace"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- Footer: entry count -->
        <Border Grid.Row="3"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                Background="{DynamicResource BackgroundStatusBarBrush}">
            <TextBlock Text="{Binding EntryCountText}"
                       FontSize="{StaticResource FontSizeXs}"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
        </Border>

    </Grid>

</UserControl>
