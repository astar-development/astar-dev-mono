<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AStar.Dev.OneDriveSync.ViewModels"
             xmlns:views="clr-namespace:AStar.Dev.OneDriveSync.Views"
             xmlns:loc="clr-namespace:AStar.Dev.OneDriveSync.Localisation"
             x:Class="AStar.Dev.OneDriveSync.Views.AccountsView"
             x:DataType="vm:AccountsViewModel">

    <Grid RowDefinitions="*">

        <!-- Empty state -->
        <StackPanel Grid.Row="0"
                    IsVisible="{Binding !HasAccounts}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">

            <Viewbox Width="48" Height="48" HorizontalAlignment="Center">
                <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource BorderDefaultBrush}"
                          Data="M19.35,10.04 C18.67,6.59 15.64,4 12,4
                                C9.11,4 6.6,5.64 5.35,8.04
                                C2.34,8.36 0,10.91 0,14
                                C0,17.31 2.69,20 6,20 H19
                                C21.76,20 24,17.76 24,15
                                C24,12.36 21.95,10.22 19.35,10.04 Z"/>
                </Canvas>
            </Viewbox>

            <TextBlock Text="{loc:Localize Accounts_NoAccountsTitle}"
                       FontSize="{StaticResource FontSizeLg}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{loc:Localize Accounts_NoAccountsMessage}"
                       FontSize="{StaticResource FontSizeMd}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="280"/>

            <Button HorizontalAlignment="Center"
                    Padding="16,8"
                    Margin="0,8,0,0"
                    CornerRadius="{StaticResource RadiusMd}"
                    Background="{DynamicResource TextAccentBrush}"
                    Foreground="{DynamicResource TextOnAccentBrush}"
                    BorderThickness="0"
                    Command="{Binding AddAccountCommand}">
                <TextBlock Text="{loc:Localize Accounts_AddAccount}"
                           FontSize="{StaticResource FontSizeMd}"
                           Foreground="{DynamicResource TextOnAccentBrush}"/>
            </Button>

        </StackPanel>

        <!-- Account list -->
        <ScrollViewer Grid.Row="0"
                      IsVisible="{Binding HasAccounts}"
                      Padding="24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <TextBlock Text="{loc:Localize Accounts_ConnectedAccounts}"
                           FontSize="{StaticResource FontSizeXl}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccountCardViewModel">

                            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusLg}"
                                    Padding="16"
                                    Margin="0,0,0,4"
                                    Cursor="Hand">

                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <!-- Avatar: initials circle -->
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="22"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource TextAccentBrush}">
                                        <TextBlock Text="{Binding Initials}"
                                                   FontSize="{StaticResource FontSizeMd}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="{StaticResource FontSizeMd}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="{StaticResource FontSizeSm}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding LastSyncText}"
                                                   FontSize="{StaticResource FontSizeXs}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Padding="8,4"
                                            CornerRadius="{StaticResource RadiusSm}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding RemoveCommand}"
                                            ToolTip.Tip="{loc:Localize Accounts_RemoveAccountTooltip}">
                                        <TextBlock Text="✕"
                                                   FontSize="{StaticResource FontSizeSm}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </Button>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button HorizontalAlignment="Left"
                        Padding="12,6"
                        Margin="0,8,0,0"
                        CornerRadius="{StaticResource RadiusMd}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        Command="{Binding AddAccountCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="+"
                                   FontSize="{StaticResource FontSizeLg}"
                                   Foreground="{DynamicResource TextAccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Localize Accounts_AddAnotherAccount}"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{DynamicResource TextAccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <!-- Wizard overlay -->
        <Grid Grid.Row="0"
              IsVisible="{Binding IsWizardVisible}"
              Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusXl}"
                    Padding="32"
                    Width="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <ContentControl Content="{Binding Wizard}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:AddAccountWizardViewModel">
                            <views:AddAccountWizardView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>

            </Border>
        </Grid>

        <!-- AM-08: Remove account confirmation overlay -->
        <Grid Grid.Row="0"
              IsVisible="{Binding IsRemovePromptVisible}"
              Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusXl}"
                    Padding="32"
                    Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="{loc:Localize Accounts_RemoveTitle}"
                               FontSize="{StaticResource FontSizeXl}"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="{Binding RemovePromptAccountEmail}"
                               FontSize="{StaticResource FontSizeMd}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <TextBlock Text="{loc:Localize Accounts_RemoveMessage}"
                               FontSize="{StaticResource FontSizeSm}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="{loc:Localize Common_Cancel}"
                                Padding="12,6"
                                CornerRadius="{StaticResource RadiusMd}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                Command="{Binding CancelRemoveCommand}"/>

                        <Button Content="{loc:Localize Accounts_RemoveKeep}"
                                Padding="12,6"
                                CornerRadius="{StaticResource RadiusMd}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                Command="{Binding ConfirmRemoveKeepCommand}"/>

                        <Button Padding="12,6"
                                CornerRadius="{StaticResource RadiusMd}"
                                Background="{DynamicResource StatusErrorBrush}"
                                BorderThickness="0"
                                Command="{Binding ConfirmRemoveDeleteCommand}">
                            <TextBlock Text="{loc:Localize Accounts_RemoveDelete}"
                                       Foreground="{DynamicResource TextOnAccentBrush}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>

</UserControl>
