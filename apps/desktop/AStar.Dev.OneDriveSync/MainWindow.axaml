<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AStar.Dev.OneDriveSync.MainWindow"
        Width="800" Height="600">
    <!-- Title is set from LocalisationService in App.axaml.cs (TI-03) -->
    <DockPanel>

        <!-- ── Top bar ────────────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="12,8">

            <TextBlock Text="Theme:"
                       VerticalAlignment="Center" />

            <!-- TI-01: theme selector — Light / Dark / System (Auto).
                 Additional modes can be appended to ThemeOptions post-MVP. -->
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedThemeOption}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

        </StackPanel>

        <!-- Main content area — populated in future iterations -->
        <Grid />

    </DockPanel>
</Window>
