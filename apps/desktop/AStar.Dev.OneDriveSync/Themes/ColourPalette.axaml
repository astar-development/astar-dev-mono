<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        ColourPalette.axaml — semantic colour tokens (TI-02)
        All custom colours used by the app are defined here.
        No hardcoded colour values are permitted in any other AXAML file.
        Resources are resolved automatically by Avalonia based on RequestedThemeVariant.
    -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppPrimaryColour">#0078D4</Color>
            <Color x:Key="AppSurfaceColour">#FFFFFF</Color>
            <Color x:Key="AppOnSurfaceColour">#1A1A1A</Color>
            <Color x:Key="AppBorderColour">#D1D1D1</Color>

            <SolidColorBrush x:Key="AppPrimaryBrush"   Color="{StaticResource AppPrimaryColour}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"   Color="{StaticResource AppSurfaceColour}" />
            <SolidColorBrush x:Key="AppOnSurfaceBrush" Color="{StaticResource AppOnSurfaceColour}" />
            <SolidColorBrush x:Key="AppBorderBrush"    Color="{StaticResource AppBorderColour}" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppPrimaryColour">#4FC3F7</Color>
            <Color x:Key="AppSurfaceColour">#1E1E1E</Color>
            <Color x:Key="AppOnSurfaceColour">#E8E8E8</Color>
            <Color x:Key="AppBorderColour">#3A3A3A</Color>

            <SolidColorBrush x:Key="AppPrimaryBrush"   Color="{StaticResource AppPrimaryColour}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"   Color="{StaticResource AppSurfaceColour}" />
            <SolidColorBrush x:Key="AppOnSurfaceBrush" Color="{StaticResource AppOnSurfaceColour}" />
            <SolidColorBrush x:Key="AppBorderBrush"    Color="{StaticResource AppBorderColour}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
