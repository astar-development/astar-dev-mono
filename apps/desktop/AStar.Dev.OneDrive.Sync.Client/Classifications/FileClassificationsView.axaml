<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:classifications="clr-namespace:AStar.Dev.OneDrive.Sync.Client.Classifications"
             x:Class="AStar.Dev.OneDrive.Sync.Client.Classifications.FileClassificationsView"
             x:DataType="classifications:FileClassificationRulesViewModel"
             VerticalContentAlignment="Stretch"
             HorizontalContentAlignment="Stretch">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Margin="24,20,24,12">
            <StackPanel Grid.Column="0"
                        Spacing="4">
                <TextBlock Text="File classifications"
                           FontSize="{StaticResource FontSizeXl}"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Manage the category hierarchy and keywords used to classify files during sync."
                           FontSize="{StaticResource FontSizeSm}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Export"
                        Padding="8,4"
                        CornerRadius="{StaticResource RadiusMd}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        FontSize="{StaticResource FontSizeSm}"
                        Click="OnExportClick"/>
                <Button Content="Import"
                        Padding="8,4"
                        CornerRadius="{StaticResource RadiusMd}"
                        Background="{DynamicResource TextAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="{StaticResource FontSizeSm}"
                        Click="OnImportClick"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MinHeight="0"
                      Padding="24,0,34,20">
            <StackPanel Spacing="12" MaxWidth="640">

                <!-- Loading state -->
                <TextBlock Text="{Binding LoadingText}"
                           FontSize="{StaticResource FontSizeSm}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           IsVisible="{Binding IsLoading}"/>

                <!-- Empty state -->
                <TextBlock Text="No classification categories defined."
                           FontSize="{StaticResource FontSizeSm}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           IsVisible="{Binding HasNoCategories}"/>

                <!-- Category tree -->
                <ItemsControl ItemsSource="{Binding Categories}"
                              IsVisible="{Binding !HasNoCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="classifications:CategoryNodeViewModel">
                            <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Padding="12,10"
                                    Margin="0,0,0,6">
                                <StackPanel Spacing="8">

                                    <!-- Category header row -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeMd}"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusSm}"
                                                    Padding="4,1">
                                                <TextBlock Text="{Binding Level, StringFormat='L{0}'}"
                                                           FontSize="{StaticResource FontSizeXs}"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Delete"
                                                Padding="8,4"
                                                CornerRadius="{StaticResource RadiusMd}"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                FontSize="{StaticResource FontSizeXs}"
                                                Command="{Binding DeleteSelfCommand}"/>
                                    </Grid>

                                    <!-- Keywords list -->
                                    <ItemsControl ItemsSource="{Binding Keywords}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="classifications:KeywordRowViewModel">
                                                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                        CornerRadius="{StaticResource RadiusSm}"
                                                        Padding="8,6"
                                                        Margin="0,0,0,4">
                                                    <Grid ColumnDefinitions="*,Auto">

                                                        <!-- View mode -->
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    VerticalAlignment="Center"
                                                                    IsVisible="{Binding !IsEditing}">
                                                            <TextBlock Text="{Binding Value}"
                                                                       FontSize="{StaticResource FontSizeSm}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Background="{DynamicResource TextAccentBrush}"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Padding="4,1"
                                                                    IsVisible="{Binding IsFamous}">
                                                                <TextBlock Text="Special"
                                                                           FontSize="{StaticResource FontSizeXs}"
                                                                           Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Edit mode -->
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    VerticalAlignment="Center"
                                                                    IsVisible="{Binding IsEditing}">
                                                            <TextBox Text="{Binding Value}"
                                                                     FontSize="{StaticResource FontSizeSm}"
                                                                     CornerRadius="{StaticResource RadiusSm}"
                                                                     MinWidth="160"/>
                                                            <CheckBox Content="Special"
                                                                      IsChecked="{Binding IsFamous}"
                                                                      FontSize="{StaticResource FontSizeSm}"
                                                                      VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <!-- Action buttons -->
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    VerticalAlignment="Center">
                                                            <Button Content="Edit"
                                                                    Padding="6,3"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    FontSize="{StaticResource FontSizeXs}"
                                                                    Command="{Binding EditCommand}"
                                                                    IsVisible="{Binding !IsEditing}"/>
                                                            <Button Content="Save"
                                                                    Padding="6,3"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Background="{DynamicResource TextAccentBrush}"
                                                                    Foreground="White"
                                                                    BorderThickness="0"
                                                                    FontSize="{StaticResource FontSizeXs}"
                                                                    Command="{Binding SaveCommand}"
                                                                    IsVisible="{Binding IsEditing}"/>
                                                            <Button Content="Cancel"
                                                                    Padding="6,3"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    FontSize="{StaticResource FontSizeXs}"
                                                                    Command="{Binding CancelCommand}"
                                                                    IsVisible="{Binding IsEditing}"/>
                                                            <Button Content="Delete"
                                                                    Padding="6,3"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    FontSize="{StaticResource FontSizeXs}"
                                                                    Command="{Binding DeleteCommand}"
                                                                    IsVisible="{Binding !IsEditing}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Add keyword form (leaf nodes only) -->
                                    <StackPanel Spacing="6"
                                                IsVisible="{Binding Keywords.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    IsVisible="{Binding Children.Count, Converter={x:Static ObjectConverters.IsNull}}">
                                            <TextBox Text="{Binding NewKeyword}"
                                                     PlaceholderText="New keyword"
                                                     FontSize="{StaticResource FontSizeSm}"
                                                     CornerRadius="{StaticResource RadiusSm}"
                                                     MinWidth="180"/>
                                            <CheckBox Content="Famous"
                                                      IsChecked="{Binding IsFamous}"
                                                      FontSize="{StaticResource FontSizeSm}"
                                                      VerticalAlignment="Center"
                                                      MinWidth="180"/>
                                            <CheckBox Content="Internet"
                                                      IsChecked="{Binding IsInternet}"
                                                      FontSize="{StaticResource FontSizeSm}"
                                                      VerticalAlignment="Center"/>
                                            <Button Content="Add keyword"
                                                    Padding="8,4"
                                                    CornerRadius="{StaticResource RadiusMd}"
                                                    Background="{DynamicResource TextAccentBrush}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="{StaticResource FontSizeSm}"
                                                    Command="{Binding AddKeywordCommand}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Add sub-category form (max level 3) -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <TextBox Text="{Binding NewChildCategoryName}"
                                                 PlaceholderText="New sub-category"
                                                 FontSize="{StaticResource FontSizeSm}"
                                                 CornerRadius="{StaticResource RadiusSm}"
                                                 MinWidth="180"
                                                 IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <Button Content="Add sub-category"
                                                Padding="8,4"
                                                CornerRadius="{StaticResource RadiusMd}"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Command="{Binding AddChildCategoryCommand}"
                                                IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    </StackPanel>

                                    <!-- Children (nested with left indent) -->
                                    <ItemsControl ItemsSource="{Binding Children}"
                                                  Margin="16,0,0,0"
                                                  IsVisible="{Binding Children.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="classifications:CategoryNodeViewModel">
                                                <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource RadiusMd}"
                                                        Padding="10,8"
                                                        Margin="0,0,0,4">
                                                    <StackPanel Spacing="6">

                                                        <!-- Child category header -->
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="{StaticResource FontSizeSm}"
                                                                           FontWeight="Medium"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                        Padding="4,1">
                                                                    <TextBlock Text="{Binding Level, StringFormat='L{0}'}"
                                                                               FontSize="{StaticResource FontSizeXs}"
                                                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Content="Delete"
                                                                    Padding="6,3"
                                                                    CornerRadius="{StaticResource RadiusSm}"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    FontSize="{StaticResource FontSizeXs}"
                                                                    Command="{Binding DeleteSelfCommand}"/>
                                                        </Grid>

                                                        <!-- Child keywords list -->
                                                        <ItemsControl ItemsSource="{Binding Keywords}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="classifications:KeywordRowViewModel">
                                                                    <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                            Padding="8,6"
                                                                            Margin="0,0,0,4">
                                                                        <Grid ColumnDefinitions="*,Auto">
                                                                            <StackPanel Grid.Column="0"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="6"
                                                                                        VerticalAlignment="Center"
                                                                                        IsVisible="{Binding !IsEditing}">
                                                                                <TextBlock Text="{Binding Value}"
                                                                                           FontSize="{StaticResource FontSizeSm}"
                                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                           VerticalAlignment="Center"/>
                                                                                <Border Background="{DynamicResource TextAccentBrush}"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Padding="4,1"
                                                                                        IsVisible="{Binding IsFamous}">
                                                                                    <TextBlock Text="Special"
                                                                                               FontSize="{StaticResource FontSizeXs}"
                                                                                               Foreground="White"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="0"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="6"
                                                                                        VerticalAlignment="Center"
                                                                                        IsVisible="{Binding IsEditing}">
                                                                                <TextBox Text="{Binding Value}"
                                                                                         FontSize="{StaticResource FontSizeSm}"
                                                                                         CornerRadius="{StaticResource RadiusSm}"
                                                                                         MinWidth="140"/>
                                                                                <CheckBox Content="Special"
                                                                                          IsChecked="{Binding IsFamous}"
                                                                                          FontSize="{StaticResource FontSizeSm}"
                                                                                          VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="1"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="6"
                                                                                        VerticalAlignment="Center">
                                                                                <Button Content="Edit"
                                                                                        Padding="6,3"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                        BorderThickness="1"
                                                                                        FontSize="{StaticResource FontSizeXs}"
                                                                                        Command="{Binding EditCommand}"
                                                                                        IsVisible="{Binding !IsEditing}"/>
                                                                                <Button Content="Save"
                                                                                        Padding="6,3"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Background="{DynamicResource TextAccentBrush}"
                                                                                        Foreground="White"
                                                                                        BorderThickness="0"
                                                                                        FontSize="{StaticResource FontSizeXs}"
                                                                                        Command="{Binding SaveCommand}"
                                                                                        IsVisible="{Binding IsEditing}"/>
                                                                                <Button Content="Cancel"
                                                                                        Padding="6,3"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                        BorderThickness="1"
                                                                                        FontSize="{StaticResource FontSizeXs}"
                                                                                        Command="{Binding CancelCommand}"
                                                                                        IsVisible="{Binding IsEditing}"/>
                                                                                <Button Content="Delete"
                                                                                        Padding="6,3"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                        BorderThickness="1"
                                                                                        FontSize="{StaticResource FontSizeXs}"
                                                                                        Command="{Binding DeleteCommand}"
                                                                                        IsVisible="{Binding !IsEditing}"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- Add keyword form for child (leaf only) -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    IsVisible="{Binding Children.Count, Converter={x:Static ObjectConverters.IsNull}}">
                                                            <TextBox Text="{Binding NewKeyword}"
                                                                     PlaceholderText="New keyword"
                                                                     FontSize="{StaticResource FontSizeSm}"
                                                                     CornerRadius="{StaticResource RadiusSm}"
                                                                     MinWidth="160"/>
                                                            <CheckBox Content="Special"
                                                                      IsChecked="{Binding IsFamous}"
                                                                      FontSize="{StaticResource FontSizeSm}"
                                                                      VerticalAlignment="Center"/>
                                                            <CheckBox Content="Internet"
                                                                    IsChecked="{Binding IsInternet}"
                                                                    FontSize="{StaticResource FontSizeSm}"
                                                                    VerticalAlignment="Center"/>
                                                            <Button Content="Add keyword"
                                                                    Padding="8,4"
                                                                    CornerRadius="{StaticResource RadiusMd}"
                                                                    Background="{DynamicResource TextAccentBrush}"
                                                                    Foreground="White"
                                                                    BorderThickness="0"
                                                                    FontSize="{StaticResource FontSizeSm}"
                                                                    Command="{Binding AddKeywordCommand}"/>
                                                        </StackPanel>

                                                        <!-- Add grandchild category form (level 2 only, max level 3) -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                            <TextBox Text="{Binding NewChildCategoryName}"
                                                                     PlaceholderText="New sub-category"
                                                                     FontSize="{StaticResource FontSizeSm}"
                                                                     CornerRadius="{StaticResource RadiusSm}"
                                                                     MinWidth="160"
                                                                     IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                            <Button Content="Add sub-category"
                                                                    Padding="8,4"
                                                                    CornerRadius="{StaticResource RadiusMd}"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    FontSize="{StaticResource FontSizeSm}"
                                                                    Command="{Binding AddChildCategoryCommand}"
                                                                    IsVisible="{Binding Level, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                        </StackPanel>

                                                        <!-- Grandchildren (level 3, no further nesting) -->
                                                        <ItemsControl ItemsSource="{Binding Children}"
                                                                      Margin="12,0,0,0"
                                                                      IsVisible="{Binding Children.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="classifications:CategoryNodeViewModel">
                                                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                            Padding="8,6"
                                                                            Margin="0,0,0,4">
                                                                        <StackPanel Spacing="6">
                                                                            <Grid ColumnDefinitions="*,Auto">
                                                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               FontSize="{StaticResource FontSizeSm}"
                                                                                               FontWeight="Medium"
                                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                                                            BorderThickness="1"
                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                            Padding="4,1">
                                                                                        <TextBlock Text="{Binding Level, StringFormat='L{0}'}"
                                                                                                   FontSize="{StaticResource FontSizeXs}"
                                                                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                                                    </Border>
                                                                                </StackPanel>
                                                                                <Button Grid.Column="1"
                                                                                        Content="Delete"
                                                                                        Padding="6,3"
                                                                                        CornerRadius="{StaticResource RadiusSm}"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                        BorderThickness="1"
                                                                                        FontSize="{StaticResource FontSizeXs}"
                                                                                        Command="{Binding DeleteSelfCommand}"/>
                                                                            </Grid>
                                                                            <ItemsControl ItemsSource="{Binding Keywords}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate DataType="classifications:KeywordRowViewModel">
                                                                                        <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                                                                CornerRadius="{StaticResource RadiusSm}"
                                                                                                Padding="6,4"
                                                                                                Margin="0,0,0,2">
                                                                                            <Grid ColumnDefinitions="*,Auto">
                                                                                                <StackPanel Grid.Column="0"
                                                                                                            Orientation="Horizontal"
                                                                                                            Spacing="6"
                                                                                                            VerticalAlignment="Center"
                                                                                                            IsVisible="{Binding !IsEditing}">
                                                                                                    <TextBlock Text="{Binding Value}"
                                                                                                               FontSize="{StaticResource FontSizeSm}"
                                                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                                               VerticalAlignment="Center"/>
                                                                                                    <Border Background="{DynamicResource TextAccentBrush}"
                                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                                            Padding="4,1"
                                                                                                            IsVisible="{Binding IsFamous}">
                                                                                                        <TextBlock Text="Special"
                                                                                                                   FontSize="{StaticResource FontSizeXs}"
                                                                                                                   Foreground="White"/>
                                                                                                    </Border>
                                                                                                </StackPanel>
                                                                                                <StackPanel Grid.Column="0"
                                                                                                            Orientation="Horizontal"
                                                                                                            Spacing="6"
                                                                                                            VerticalAlignment="Center"
                                                                                                            IsVisible="{Binding IsEditing}">
                                                                                                    <TextBox Text="{Binding Value}"
                                                                                                             FontSize="{StaticResource FontSizeSm}"
                                                                                                             CornerRadius="{StaticResource RadiusSm}"
                                                                                                             MinWidth="120"/>
                                                                                                    <CheckBox Content="Special"
                                                                                                              IsChecked="{Binding IsFamous}"
                                                                                                              FontSize="{StaticResource FontSizeSm}"
                                                                                                              VerticalAlignment="Center"/>
                                                                                                </StackPanel>
                                                                                                <StackPanel Grid.Column="1"
                                                                                                            Orientation="Horizontal"
                                                                                                            Spacing="6"
                                                                                                            VerticalAlignment="Center">
                                                                                                    <Button Content="Edit"
                                                                                                            Padding="6,3"
                                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                                            Background="Transparent"
                                                                                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                                            BorderThickness="1"
                                                                                                            FontSize="{StaticResource FontSizeXs}"
                                                                                                            Command="{Binding EditCommand}"
                                                                                                            IsVisible="{Binding !IsEditing}"/>
                                                                                                    <Button Content="Save"
                                                                                                            Padding="6,3"
                                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                                            Background="{DynamicResource TextAccentBrush}"
                                                                                                            Foreground="White"
                                                                                                            BorderThickness="0"
                                                                                                            FontSize="{StaticResource FontSizeXs}"
                                                                                                            Command="{Binding SaveCommand}"
                                                                                                            IsVisible="{Binding IsEditing}"/>
                                                                                                    <Button Content="Cancel"
                                                                                                            Padding="6,3"
                                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                                            Background="Transparent"
                                                                                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                                            BorderThickness="1"
                                                                                                            FontSize="{StaticResource FontSizeXs}"
                                                                                                            Command="{Binding CancelCommand}"
                                                                                                            IsVisible="{Binding IsEditing}"/>
                                                                                                    <Button Content="Delete"
                                                                                                            Padding="6,3"
                                                                                                            CornerRadius="{StaticResource RadiusSm}"
                                                                                                            Background="Transparent"
                                                                                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                                                            BorderThickness="1"
                                                                                                            FontSize="{StaticResource FontSizeXs}"
                                                                                                            Command="{Binding DeleteCommand}"
                                                                                                            IsVisible="{Binding !IsEditing}"/>
                                                                                                </StackPanel>
                                                                                            </Grid>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                            <StackPanel Orientation="Horizontal"
                                                                                        Spacing="6">
                                                                                <TextBox Text="{Binding NewKeyword}"
                                                                                         PlaceholderText="New keyword"
                                                                                         FontSize="{StaticResource FontSizeSm}"
                                                                                         CornerRadius="{StaticResource RadiusSm}"
                                                                                         MinWidth="140"/>
                                                                                <CheckBox Content="Special"
                                                                                          IsChecked="{Binding IsFamous}"
                                                                                          FontSize="{StaticResource FontSizeSm}"
                                                                                          VerticalAlignment="Center"/>
                                                                                <CheckBox Content="Internet"
                                                                                        IsChecked="{Binding IsInternet}"
                                                                                        FontSize="{StaticResource FontSizeSm}"
                                                                                        VerticalAlignment="Center"/>
                                                                                <Button Content="Add keyword"
                                                                                        Padding="8,4"
                                                                                        CornerRadius="{StaticResource RadiusMd}"
                                                                                        Background="{DynamicResource TextAccentBrush}"
                                                                                        Foreground="White"
                                                                                        BorderThickness="0"
                                                                                        FontSize="{StaticResource FontSizeSm}"
                                                                                        Command="{Binding AddKeywordCommand}"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add root category form -->
                <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Padding="12"
                        Margin="0,0,0,28">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Add category"
                                   FontSize="{StaticResource FontSizeXs}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding NewCategoryName}"
                                    PlaceholderText="Category name"
                                    FontSize="{StaticResource FontSizeSm}"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    MinWidth="220"/>
                            <CheckBox Content="Famous"
                                    IsChecked="{Binding IsFamous}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    VerticalAlignment="Center"/>
                            <CheckBox Content="Internet"
                                    IsChecked="{Binding IsInternet}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    VerticalAlignment="Center"/>
                            <Button Content="Add"
                                    Padding="14,6"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Background="{DynamicResource TextAccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Command="{Binding AddCategoryCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
