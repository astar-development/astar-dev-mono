<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AStar.Dev.OneDrive.Sync.Client.Splash.SplashWindow"
        Width="400" Height="260"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="12">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="16">

            <Viewbox Width="48" Height="48"
                     HorizontalAlignment="Center">
                <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource TextAccentBrush}"
                          Data="M19.35,10.04 C18.67,6.59 15.64,4 12,4
                                C9.11,4 6.6,5.64 5.35,8.04
                                C2.34,8.36 0,10.91 0,14
                                C0,17.31 2.69,20 6,20 H19
                                C21.76,20 24,17.76 24,15
                                C24,12.36 21.95,10.22 19.35,10.04 Z"/>
                </Canvas>
            </Viewbox>

            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="OneDrive Sync"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Starting up…"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ProgressBar IsIndeterminate="True"
                         Width="200"
                         Height="3"
                         HorizontalAlignment="Center"/>

        </StackPanel>

    </Border>

</Window>
