<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AStar.Dev.Wallpaper.Scrapper.Dialogs.ConfirmationDialog"
        Title="Confirm"
        Width="400"
        Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="20">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="YesButton" Content="Yes" Click="OnYesClicked" />
            <Button x:Name="NoButton" Content="No" Click="OnNoClicked" />
        </StackPanel>
    </StackPanel>
</Window>
